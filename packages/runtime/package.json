{
  "name": "@brna/runtime",
  "version": "0.1.3",
  "description": "In-app runtime: fiber walker, a11y reader, action dispatcher, snapshot serialiser",
  "repository": {
    "type": "git",
    "url": "https://github.com/leolin310148/brna"
  },
  "type": "module",
  "main": "./index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./index.js"
    },
    "./auto": {
      "types": "./src/auto.ts",
      "default": "./auto.js"
    },
    "./auto.js": {
      "types": "./src/auto.ts",
      "default": "./auto.js"
    }
  },
  "files": [
    "dist",
    "src",
    "index.js",
    "auto.js"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun build src/index.ts src/auto.ts --outdir dist --target browser --format esm --external react --external react-native",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@brna/schema": "^0.1.3",
    "@brna/core": "^0.1.3"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.74.0"
  }
}
