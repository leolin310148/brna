{
  "name": "@brna/mcp",
  "version": "0.0.6",
  "description": "MCP stdio server bridging Claude/MCP clients to a brna runtime via Metro",
  "repository": {
    "type": "git",
    "url": "https://github.com/leolin310148/brna"
  },
  "type": "module",
  "bin": {
    "brna-mcp": "./dist/brna-mcp"
  },
  "files": [
    "dist",
    "src"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build ./src/server.ts --compile --outfile dist/brna-mcp",
    "prepack": "bun run build",
    "start": "bun run ./src/server.ts"
  },
  "dependencies": {
    "@brna/core": "^0.0.6",
    "@brna/schema": "^0.0.6",
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
