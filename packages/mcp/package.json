{
  "name": "@brna/mcp",
  "version": "0.0.7",
  "description": "MCP stdio server bridging Claude/MCP clients to a brna runtime via Metro",
  "repository": {
    "type": "git",
    "url": "https://github.com/leolin310148/brna"
  },
  "type": "module",
  "bin": {
    "brna-mcp": "./dist/brna-mcp.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "node -e \"require('node:fs').rmSync('dist/brna-mcp',{force:true})\" && bun build ./src/server.ts --target=node --outfile dist/brna-mcp.js",
    "prepack": "bun run build",
    "start": "bun run ./src/server.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@brna/core": "^0.0.7",
    "@brna/schema": "^0.0.7",
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
