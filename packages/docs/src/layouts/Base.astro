---
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | brna</title>
    <style>
      :root {
        color-scheme: light;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: #172033;
        background: #f8fafc;
      }
      body { margin: 0; }
      a { color: #0f6b5f; }
      header {
        border-bottom: 1px solid #d9e2ec;
        background: #ffffff;
      }
      nav {
        max-width: 1080px;
        margin: 0 auto;
        min-height: 56px;
        display: flex;
        align-items: center;
        gap: 24px;
        padding: 0 20px;
      }
      nav strong { font-size: 18px; }
      nav a { text-decoration: none; color: #334155; }
      main {
        max-width: 1080px;
        margin: 0 auto;
        padding: 32px 20px 56px;
      }
      h1 { font-size: 36px; line-height: 1.1; margin: 0 0 12px; }
      h2 { font-size: 24px; margin: 36px 0 12px; }
      h3 { font-size: 18px; margin: 0 0 8px; }
      p { line-height: 1.6; }
      code, pre {
        font-family: "SFMono-Regular", Consolas, monospace;
      }
      pre {
        overflow: auto;
        padding: 14px;
        border: 1px solid #d9e2ec;
        border-radius: 8px;
        background: #0f172a;
        color: #f8fafc;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 14px;
      }
      .card {
        border: 1px solid #d9e2ec;
        border-radius: 8px;
        background: #ffffff;
        padding: 16px;
      }
      .muted { color: #64748b; }
      .search {
        width: 100%;
        box-sizing: border-box;
        height: 42px;
        border: 1px solid #b8c4d2;
        border-radius: 6px;
        padding: 0 12px;
        font: inherit;
      }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <strong>brna</strong>
        <a href="/">Docs</a>
        <a href="/cli">CLI</a>
        <a href="/agents">Agents</a>
        <a href="/cookbooks">Cookbooks</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
