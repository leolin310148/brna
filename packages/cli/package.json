{
  "name": "@brna/cli",
  "version": "0.0.4",
  "description": "brna CLI — agent-friendly snapshot and action surface for React Native apps",
  "repository": {
    "type": "git",
    "url": "https://github.com/leolin310148/brna"
  },
  "type": "module",
  "bin": {
    "brna": "./src/cli.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build ./src/cli.ts --compile --outfile dist/brna",
    "start": "bun run ./src/cli.ts"
  },
  "dependencies": {
    "@brna/schema": "workspace:*",
    "@brna/core": "workspace:*",
    "@brna/mcp": "workspace:*"
  }
}
