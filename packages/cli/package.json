{
  "name": "@brna/cli",
  "version": "0.0.5",
  "description": "brna CLI — agent-friendly snapshot and action surface for React Native apps",
  "repository": {
    "type": "git",
    "url": "https://github.com/leolin310148/brna"
  },
  "type": "module",
  "bin": {
    "brna": "./dist/brna"
  },
  "files": [
    "dist",
    "src"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build ./src/cli.ts --compile --outfile dist/brna",
    "prepack": "bun run build",
    "start": "bun run ./src/cli.ts"
  },
  "dependencies": {
    "@brna/schema": "^0.0.5",
    "@brna/core": "^0.0.5",
    "@brna/mcp": "^0.0.5"
  }
}
