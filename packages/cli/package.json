{
  "name": "@brna/cli",
  "version": "0.1.3",
  "description": "brna CLI — agent-friendly snapshot and action surface for React Native apps",
  "repository": {
    "type": "git",
    "url": "https://github.com/leolin310148/brna"
  },
  "type": "module",
  "bin": {
    "brna": "./dist/brna.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "node -e \"require('node:fs').rmSync('dist/brna',{force:true})\" && bun build ./src/cli.ts --target=node --outfile dist/brna.js",
    "prepack": "bun run build",
    "start": "bun run ./src/cli.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@brna/schema": "^0.1.3",
    "@brna/core": "^0.1.3",
    "@brna/mcp": "^0.1.3"
  }
}
