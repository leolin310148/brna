{
  "name": "@brna/metro-plugin",
  "version": "0.0.7",
  "description": "Expo config plugin + Metro middleware: HTTP/WebSocket surface inside Metro process",
  "repository": {
    "type": "git",
    "url": "https://github.com/leolin310148/brna"
  },
  "main": "./dist/index.cjs",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.cjs"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build src/index.ts --outfile dist/index.cjs --target node --format cjs --external ws",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@brna/schema": "^0.0.7",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.12"
  },
  "peerDependencies": {
    "metro": "*",
    "expo": "*"
  }
}
