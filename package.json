{
  "name": "brna-monorepo",
  "private": true,
  "version": "0.0.7",
  "description": "Bring React Native Agent-friendly — monorepo root",
  "repository": {
    "type": "git",
    "url": "https://github.com/leolin310148/brna"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:schema": "bun --filter '@brna/schema' build:schema",
    "e2e:expo-sample": "bun test e2e/expo-sample.test.ts",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun --filter '@brna/schema' test && bun --filter '@brna/core' test"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/bun": "latest"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
